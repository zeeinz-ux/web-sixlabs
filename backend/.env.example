# ============================================
# SixLabs Backend — Environment Variables
# ============================================

# Server Configuration (Required)
PORT=5000
NODE_ENV=development

# CORS — Frontend URL (Required)
FRONTEND_URL=http://localhost:5173

============================================
Placeholder for Future Stages
============================================

AI Provider API Keys (Tahap 3 — AI Integration)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

Firebase Configuration (Tahap 5 — Firestore Logging)
FIREBASE_PROJECT_ID= your_firebase_project_id_here
FIREBASE_CLIENT_EMAIL=your_firebase_client_email_here
FIREBASE_PRIVATE_KEY=your_firebase_private_key_here

Google Sheets (Tahap 6 — Sheets Sync)
GOOGLE_SHEETS_ID=your_google_sheets_id_here

Security (Tahap 4 — Authentication)
JWT_SECRET==your_jwt_secret_here
